# CyberClaw 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env

# ==================== 模型配置 ====================

# 默认模型提供商 (可选：openai, anthropic, aliyun, tencent, z.ai, ollama, other)
DEFAULT_PROVIDER=openai

# 默认模型名称
DEFAULT_MODEL=gpt-5.4

# planner / route-classifier 轻量模型
# 不填写时会回退到 DEFAULT_MODEL
# ROUTE_CLASSIFIER_MODEL=gpt-5.4

# ==================== OpenAI 配置 ====================
# 仅在 DEFAULT_PROVIDER=openai / other 时默认使用
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (可选，使用官方接口可留空或注释)
# OpenAI 官方：https://api.openai.com/v1
# ikuncode：https://api.ikuncode.cc/v1
OPENAI_API_BASE=https://api.ikuncode.cc/v1

# ==================== 阿里云 / Qwen 配置 ====================
# 仅在 DEFAULT_PROVIDER=aliyun / dashscope 时默认使用
# 如果配置了 ALIYUN_API_KEY，切换 DEFAULT_PROVIDER 时无需再手动覆盖 OPENAI_API_KEY
# ALIYUN_API_KEY=sk-your-qwen-api-key-here
# ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 也支持显式使用 DashScope 命名
# DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 其他兼容 Provider（可选） ====================
# 腾讯 / HunYuan
# TENCENT_API_KEY=your-tencent-key
# TENCENT_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# Z.AI
# ZAI_API_KEY=your-zai-key
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ==================== Anthropic 配置 ====================
# 仅在 DEFAULT_PROVIDER=anthropic 时使用

# API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL (可选，使用代理时配置)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==================== Tavily 搜索配置 ====================
# 仅在需要联网搜索时使用

# Tavily API Key
TAVILY_API_KEY=tvly-your-api-key-here

# ==================== 本地 arxiv_rag 配置 ====================
# MortyClaw 调用本地文献 RAG 服务时使用

# arxiv_rag API 基地址
# 如果你走 arxiv_rag 的 Feishu 风格入口，通常是宿主机 8001
ARXIV_RAG_API_BASE=http://127.0.0.1:8001

# arxiv_rag 路由模式
# auto: 简单问题走 /api/v1/ask，复杂问题走 /api/v1/ask-agentic
# ask: 始终走 /api/v1/ask，延迟最低
# agentic: 始终走 /api/v1/ask-agentic
ARXIV_RAG_ROUTE_MODE=auto

# 如需强制指定入口，可显式覆盖
# ARXIV_RAG_ASK_ENDPOINT_PATH=/api/v1/ask

# 请求超时秒数
ARXIV_RAG_TIMEOUT_SECONDS=60

# ==================== Ollama 配置 ====================
# 仅在 DEFAULT_PROVIDER=ollama 时使用

# Ollama 本地服务地址 (默认：http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
